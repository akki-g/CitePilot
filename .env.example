# App
APP_ENV=development
APP_NAME=CitePilot
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Postgres
DATABASE_URL=postgresql+asyncpg://citepilot:citepilot@postgres:5432/citepilot
POSTGRES_DB=citepilot
POSTGRES_USER=citepilot
POSTGRES_PASSWORD=citepilot

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=citepilot-password

# Redis
REDIS_URL=redis://redis:6379/0

# External scholarly APIs
OPENALEX_MAILTO=your_email@example.com   # REQUIRED: OpenAlex client refuses to start without it
SEMANTIC_SCHOLAR_API_KEY=                # optional; S2 client no-ops when empty
CROSSREF_MAILTO=your_email@example.com

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=
LLM_API_KEY=

# Embeddings
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536                       # MUST match paper_chunks.embedding column dim

# LaTeX
LATEX_WORKDIR=/tmp/citepilot-latex
LATEX_COMPILE_TIMEOUT_SECONDS=30

# Authentication
AUTH_SECRET=replace-with-at-least-32-random-bytes
SESSION_COOKIE_NAME=citepilot_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=
SESSION_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24

# Google OAuth / OpenID Connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Verification email (empty SMTP_HOST prints the verification URL in development only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_STARTTLS=true
SMTP_USE_SSL=false

# Recommended production email API (used before SMTP when configured)
RESEND_API_KEY=

# Anonymous showcase demo
DEMO_ENABLED=true
DEMO_AGENT_RUN_LIMIT=3
DEMO_PREVIEW_LIMIT=3
DEMO_QUOTA_WINDOW_HOURS=24
DEMO_MAX_SOURCE_BYTES=500000

# Legacy local tooling identity; browser API requests never use this account.
DEV_USER_ID=00000000-0000-0000-0000-000000000001
