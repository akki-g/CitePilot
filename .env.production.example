# Copy to /opt/citepilot/.env.production on EC2 and chmod 600.
# Never commit the populated file.

APP_ENV=production
APP_NAME=CitePilot
FRONTEND_URL=https://citepilot.its-akki.com
BACKEND_URL=https://citepilot.its-akki.com

POSTGRES_DB=citepilot
POSTGRES_USER=citepilot
POSTGRES_PASSWORD=replace-with-a-long-url-safe-random-secret
DATABASE_URL=postgresql+asyncpg://citepilot:replace-with-a-long-url-safe-random-secret@postgres:5432/citepilot

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-different-long-random-secret

REDIS_PASSWORD=replace-with-another-long-url-safe-random-secret
REDIS_URL=redis://:replace-with-another-long-url-safe-random-secret@redis:6379/0

OPENALEX_MAILTO=you@example.com
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=you@example.com

LLM_PROVIDER=anthropic
LLM_MODEL=
LLM_API_KEY=

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_DIM=1536

LATEX_WORKDIR=/tmp/citepilot-latex
LATEX_COMPILE_TIMEOUT_SECONDS=30

AUTH_SECRET=replace-with-at-least-48-random-characters
SESSION_COOKIE_NAME=citepilot_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
SESSION_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Recommended: Resend plus a verified sending-domain address.
RESEND_API_KEY=
SMTP_FROM_EMAIL="CitePilot <verify@updates.example.com>"

# SMTP is an alternative when RESEND_API_KEY is empty.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true
SMTP_USE_SSL=false

DEMO_ENABLED=true
DEMO_AGENT_RUN_LIMIT=3
DEMO_PREVIEW_LIMIT=3
DEMO_QUOTA_WINDOW_HOURS=24
DEMO_MAX_SOURCE_BYTES=500000

# The web gateway joins the external portfolio-edge Docker network. It does not
# publish a host port; the portfolio proxy reaches it as citepilot-web:8080.
NEO4J_HEAP_MAX=768m
NEO4J_PAGECACHE=512m
